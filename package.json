{
  "name": "llm-translate",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.5",
  "publisher": "shezw",
  "icon": "media/extension-icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "translation",
    "llm",
    "markdown",
    "comments",
    "documentation"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "media",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs",
    "package.nls.json",
    "package.nls.zh-cn.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "llmTranslate.translateFile",
        "title": "%command.translate.title%",
        "icon": {
          "light": "media/translate-light.svg",
          "dark": "media/translate-dark.svg"
        }
      },
      {
        "command": "llmTranslate.refreshFile",
        "title": "%command.refresh.title%",
        "icon": {
          "light": "media/refresh-light.svg",
          "dark": "media/refresh-dark.svg"
        }
      },
      {
        "command": "llmTranslate.translate.zh-CN",
        "title": "%command.translate.zh-CN.title%"
      },
      {
        "command": "llmTranslate.translate.en",
        "title": "%command.translate.en.title%"
      },
      {
        "command": "llmTranslate.translate.de",
        "title": "%command.translate.de.title%"
      },
      {
        "command": "llmTranslate.translate.fr",
        "title": "%command.translate.fr.title%"
      },
      {
        "command": "llmTranslate.translate.ja",
        "title": "%command.translate.ja.title%"
      },
      {
        "command": "llmTranslate.translate.ko",
        "title": "%command.translate.ko.title%"
      },
      {
        "command": "llmTranslate.refresh.zh-CN",
        "title": "%command.refresh.zh-CN.title%"
      },
      {
        "command": "llmTranslate.refresh.en",
        "title": "%command.refresh.en.title%"
      },
      {
        "command": "llmTranslate.refresh.de",
        "title": "%command.refresh.de.title%"
      },
      {
        "command": "llmTranslate.refresh.fr",
        "title": "%command.refresh.fr.title%"
      },
      {
        "command": "llmTranslate.refresh.ja",
        "title": "%command.refresh.ja.title%"
      },
      {
        "command": "llmTranslate.refresh.ko",
        "title": "%command.refresh.ko.title%"
      }
    ],
    "submenus": [
      {
        "id": "llmTranslate.contextMenu",
        "label": "%submenu.contextMenu.label%"
      },
      {
        "id": "llmTranslate.translateToMenu",
        "label": "%submenu.translateTo.label%"
      },
      {
        "id": "llmTranslate.refreshToMenu",
        "label": "%submenu.refreshTo.label%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "llmTranslate.translateFile",
          "when": "resourceScheme == file && llmTranslate.isSupported && !llmTranslate.hasTranslation",
          "group": "navigation@100"
        },
        {
          "command": "llmTranslate.refreshFile",
          "when": "resourceScheme == file && llmTranslate.isSupported && llmTranslate.hasTranslation",
          "group": "navigation@100"
        }
      ],
      "editor/context": [
        {
          "submenu": "llmTranslate.contextMenu",
          "when": "resourceScheme == file && llmTranslate.isSupported",
          "group": "2_llmTranslate@3"
        }
      ],
      "explorer/context": [
        {
          "submenu": "llmTranslate.contextMenu",
          "when": "explorerResourceIsFolder == false && resourceScheme == file",
          "group": "3_llmTranslate@3"
        }
      ],
      "llmTranslate.contextMenu": [
        {
          "submenu": "llmTranslate.translateToMenu",
          "group": "1_translate@1"
        },
        {
          "submenu": "llmTranslate.refreshToMenu",
          "group": "2_refresh@2"
        }
      ],
      "llmTranslate.translateToMenu": [
        {
          "command": "llmTranslate.translate.zh-CN",
          "group": "1"
        },
        {
          "command": "llmTranslate.translate.en",
          "group": "2"
        },
        {
          "command": "llmTranslate.translate.de",
          "group": "3"
        },
        {
          "command": "llmTranslate.translate.fr",
          "group": "4"
        },
        {
          "command": "llmTranslate.translate.ja",
          "group": "5"
        },
        {
          "command": "llmTranslate.translate.ko",
          "group": "6"
        }
      ],
      "llmTranslate.refreshToMenu": [
        {
          "command": "llmTranslate.refresh.zh-CN",
          "group": "1"
        },
        {
          "command": "llmTranslate.refresh.en",
          "group": "2"
        },
        {
          "command": "llmTranslate.refresh.de",
          "group": "3"
        },
        {
          "command": "llmTranslate.refresh.fr",
          "group": "4"
        },
        {
          "command": "llmTranslate.refresh.ja",
          "group": "5"
        },
        {
          "command": "llmTranslate.refresh.ko",
          "group": "6"
        }
      ],
      "commandPalette": [
        {
          "command": "llmTranslate.translateFile",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.refreshFile",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.translate.zh-CN",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.translate.en",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.translate.de",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.translate.fr",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.translate.ja",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.translate.ko",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.refresh.zh-CN",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.refresh.en",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.refresh.de",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.refresh.fr",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.refresh.ja",
          "when": "resourceScheme == file"
        },
        {
          "command": "llmTranslate.refresh.ko",
          "when": "resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "llmTranslate.provider": {
          "type": "string",
          "enum": [
            "auto",
            "openai-compatible",
            "ollama"
          ],
          "default": "auto",
          "description": "%configuration.provider.description%"
        },
        "llmTranslate.endpoint": {
          "type": "string",
          "default": "",
          "description": "%configuration.endpoint.description%"
        },
        "llmTranslate.model": {
          "type": "string",
          "default": "",
          "description": "%configuration.model.description%"
        },
        "llmTranslate.defaultTargetLanguage": {
          "type": "string",
          "enum": [
            "zh-CN",
            "en",
            "de",
            "fr",
            "ja",
            "ko"
          ],
          "enumItemLabels": [
            "%language.zh-CN.label%",
            "%language.en.label%",
            "%language.de.label%",
            "%language.fr.label%",
            "%language.ja.label%",
            "%language.ko.label%"
          ],
          "default": "zh-CN",
          "description": "%configuration.defaultTargetLanguage.description%"
        },
        "llmTranslate.authMode": {
          "type": "string",
          "enum": [
            "none",
            "bearer",
            "header"
          ],
          "default": "none",
          "description": "%configuration.authMode.description%"
        },
        "llmTranslate.authToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "%configuration.authToken.description%"
        },
        "llmTranslate.authHeaderName": {
          "type": "string",
          "default": "Authorization",
          "description": "%configuration.authHeaderName.description%"
        },
        "llmTranslate.authHeaderValue": {
          "type": "string",
          "default": "",
          "markdownDescription": "%configuration.authHeaderValue.description%"
        },
        "llmTranslate.cacheRoot": {
          "type": "string",
          "default": "~/llm-translate",
          "description": "%configuration.cacheRoot.description%"
        },
        "llmTranslate.requestTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 5000,
          "description": "%configuration.requestTimeoutMs.description%"
        },
        "llmTranslate.temperature": {
          "type": "number",
          "default": 0.1,
          "minimum": 0,
          "maximum": 2,
          "description": "%configuration.temperature.description%"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shezw/llm-translate-vsc-plugin.git"
  },
  "homepage": "https://github.com/shezw/llm-translate-vsc-plugin#readme",
  "bugs": {
    "url": "https://github.com/shezw/llm-translate-vsc-plugin/issues"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc -p ./ --noEmit",
    "package": "pnpm exec vsce package --yarn --no-dependencies --allow-missing-repository",
    "vscode:prepublish": "pnpm exec tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.8.2"
  }
}
